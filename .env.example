# Football API credentials
FOOTBALL_API_KEY=your_api_football_key

# JWT signing secret, required for auth
JWT_SECRET_KEY=your_random_jwt_secret

# Legacy API key support (not required for JWT auth)
API_KEY=fover_secret_secure_key_2024

# Database and cache URLs for Docker Compose
DATABASE_URL=postgresql://user:password@postgres:5432/fover_db
REDIS_URL=redis://redis:6379/0
